{
  "name": "@repo/frontend",
  "version": "2.0.0",
  "description": "Scoring System Frontend for Cloudflare Pages",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && node build.mjs",
    "build:skip-check": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=scoring-system-frontend --branch=production",
    "deploy:preview": "npm run build && wrangler pages deploy dist --project-name=scoring-system-frontend",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@number-flow/vue": "^0.5.1",
    "@repo/backend": "workspace:*",
    "@repo/shared": "workspace:*",
    "@tanstack/vue-query": "^5.101.2",
    "@tanstack/vue-table": "^8.21.3",
    "@tanstack/vue-virtual": "^3.13.31",
    "@vueuse/core": "^14.3.0",
    "@vueuse/gesture": "^2.0.0",
    "@vueuse/motion": "^3.0.3",
    "d3": "^7.9.0",
    "dayjs": "^1.11.21",
    "diff": "^9.0.0",
    "diff2html": "^3.4.56",
    "dompurify": "^3.4.11",
    "element-plus": "^2.14.2",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.27",
    "matter-js": "^0.20.0",
    "md-editor-v3": "^6.5.3",
    "papaparse": "^5.5.4",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "randomcolor": "^0.6.2",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vue-use-active-scroll": "^1.1.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@playwright/test": "^1.61.1",
    "@types/d3": "^7.4.3",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^24.13.2",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vue/eslint-config-standard": "^8.0.1",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^8.57.0",
    "happy-dom": "^20.10.6",
    "sass-embedded": "^1.100.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.0",
    "wrangler": "^4.106.0"
  }
}
